{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flutter · Android 模拟器",
      "type": "dart",
      "request": "launch",
      "cwd": "${workspaceFolder}/mobile",
      "program": "${workspaceFolder}/mobile/lib/main.dart",
      "flutterMode": "debug",
      "toolArgs": [
        "--dart-define=API_BASE_URL=http://10.0.2.2:9999/api"
      ]
    },
    {
      "name": "Flutter · Android 真机（修改电脑 IP）",
      "type": "dart",
      "request": "launch",
      "cwd": "${workspaceFolder}/mobile",
      "program": "${workspaceFolder}/mobile/lib/main.dart",
      "flutterMode": "debug",
      "toolArgs": [
        "--dart-define=API_BASE_URL=http://192.168.1.20:9999/api"
      ]
    },
    {
      "name": "Flutter · iOS 模拟器",
      "type": "dart",
      "request": "launch",
      "cwd": "${workspaceFolder}/mobile",
      "program": "${workspaceFolder}/mobile/lib/main.dart",
      "flutterMode": "debug",
      "toolArgs": [
        "--dart-define=API_BASE_URL=http://localhost:9999/api"
      ]
    },
    {
      "name": "Flutter · 生产 HTTPS 接口调试",
      "type": "dart",
      "request": "launch",
      "cwd": "${workspaceFolder}/mobile",
      "program": "${workspaceFolder}/mobile/lib/main.dart",
      "flutterMode": "debug",
      "toolArgs": [
        "--dart-define=API_BASE_URL=https://api.example.com/api"
      ]
    }
  ]
}
