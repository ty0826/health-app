{
  "name": "health-manager-taro",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.13.0",
  "description": "健康管家 H5 与微信小程序客户端",
  "scripts": {
    "dev:weapp": "taro build --type weapp --watch",
    "dev:h5": "taro build --type h5 --watch",
    "build:weapp": "taro build --type weapp",
    "build:h5": "taro build --type h5",
    "build:all": "pnpm run build:weapp && pnpm run build:h5",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --poolOptions.forks.singleFork"
  },
  "engines": {
    "node": ">=22"
  },
  "browserslist": [
    "last 3 versions",
    "Chrome >= 80",
    "iOS >= 12"
  ],
  "dependencies": {
    "@tarojs/components": "4.2.0",
    "@tarojs/helper": "4.2.0",
    "@tarojs/plugin-framework-react": "4.2.0",
    "@tarojs/plugin-platform-h5": "4.2.0",
    "@tarojs/plugin-platform-weapp": "4.2.0",
    "@tarojs/react": "4.2.0",
    "@tarojs/runtime": "4.2.0",
    "@tarojs/shared": "4.2.0",
    "@tarojs/taro": "4.2.0",
    "@tarojs/taro-h5": "4.2.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "zustand": "4.5.7"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@tarojs/cli": "4.2.0",
    "@tarojs/plugin-html": "4.2.0",
    "@tarojs/vite-runner": "4.2.0",
    "@types/node": "^22.10.0",
    "@types/react": "~18.2.45",
    "@vitejs/plugin-react": "^4.3.4",
    "postcss": "^8.4.18",
    "react-refresh": "^0.14.2",
    "sass": "^1.80.0",
    "typescript": "^5.6.0",
    "vite": "^4.5.14",
    "vitest": "2.1.8"
  }
}
