{
  "name": "health-manager",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "packageManager": "pnpm@11.13.0",
  "description": "AI + 数据可视化 + 个人健康管理系统",
  "templateInfo": {
    "name": "default",
    "typescript": true,
    "css": "sass"
  },
  "scripts": {
    "dev:weapp": "taro build --type weapp --watch",
    "dev:h5": "taro build --type h5 --watch",
    "dev:rn": "taro build --type rn --watch",
    "dev:android": "concurrently \"taro build --type rn --watch\" \"expo start --android\"",
    "dev:ios": "concurrently \"taro build --type rn --watch\" \"expo start --ios\"",
    "build:weapp": "taro build --type weapp",
    "build:h5": "taro build --type h5",
    "build:rn": "node scripts/build-rn.mjs",
    "build:android": "pnpm run build:rn && eas build --platform android",
    "build:ios": "pnpm run build:rn && eas build --platform ios",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "browserslist": [
    "last 3 versions",
    "Android >= 4.1",
    "ios >= 8"
  ],
  "dependencies": {
    "@bam.tech/react-native-image-resizer": "3.0.10",
    "@react-native-async-storage/async-storage": "1.21.0",
    "@react-native-camera-roll/camera-roll": "7.8.3",
    "@react-native-clipboard/clipboard": "1.14.3",
    "@react-native-community/geolocation": "3.4.0",
    "@react-native-community/netinfo": "11.1.0",
    "@react-native-community/slider": "4.4.2",
    "@react-native-picker/picker": "2.6.1",
    "@tarojs/cli": "4.2.0",
    "@tarojs/components": "4.2.0",
    "@tarojs/components-rn": "4.2.0",
    "@tarojs/helper": "4.2.0",
    "@tarojs/plugin-framework-react": "4.2.0",
    "@tarojs/plugin-platform-h5": "4.2.0",
    "@tarojs/plugin-platform-weapp": "4.2.0",
    "@tarojs/react": "4.2.0",
    "@tarojs/rn-supporter": "4.2.0",
    "@tarojs/runtime": "4.2.0",
    "@tarojs/runtime-rn": "4.2.0",
    "@tarojs/shared": "4.2.0",
    "@tarojs/taro": "4.2.0",
    "@tarojs/taro-h5": "4.2.0",
    "@tarojs/taro-rn": "4.2.0",
    "crypto-js": "^4.2.0",
    "expo": "~50.0.21",
    "expo-av": "~13.10.6",
    "expo-barcode-scanner": "~12.9.3",
    "expo-brightness": "~11.8.0",
    "expo-camera": "~14.1.3",
    "expo-dev-client": "~3.3.12",
    "expo-file-system": "~16.0.9",
    "expo-image-picker": "~14.7.1",
    "expo-keep-awake": "~12.8.2",
    "expo-location": "~16.5.5",
    "expo-sensors": "~12.9.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.73.6",
    "react-native-device-info": "^14.0.0",
    "react-native-gesture-handler": "2.14.0",
    "react-native-image-zoom-viewer": "3.0.1",
    "react-native-pager-view": "6.2.3",
    "react-native-root-siblings": "5.0.1",
    "react-native-safe-area-context": "4.8.2",
    "react-native-screens": "3.29.0",
    "react-native-svg": "14.1.0",
    "react-native-webview": "13.6.4",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.8.0",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-object-rest-spread": "^7.20.7",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@babel/runtime": "^7.7.7",
    "@react-native/metro-config": "0.73.5",
    "@tarojs/plugin-html": "4.2.0",
    "@tarojs/rn-runner": "4.2.0",
    "@tarojs/vite-runner": "4.2.0",
    "@types/node": "^22.10.0",
    "@types/crypto-js": "^4.2.2",
    "@types/react": "~18.2.45",
    "@vitejs/plugin-react": "^4.3.4",
    "babel-preset-taro": "4.2.0",
    "concurrently": "^9.2.1",
    "eas-cli": "^16.19.3",
    "metro-react-native-babel-preset": "0.73.10",
    "postcss": "^8.4.18",
    "react-refresh": "^0.14.2",
    "sass": "^1.80.0",
    "stylelint": "16.4.0",
    "typescript": "^5.6.0",
    "vite": "^4.5.14"
  }
}
